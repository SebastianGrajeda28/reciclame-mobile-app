{
  "name": "reciclame",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "yarn@4.9.1",
  "scripts": {
    "prepare": "husky install",
    "mobile:dev": "yarn workspace @reciclame/mobile dev",
    "mobile:start": "yarn workspace @reciclame/mobile start",
    "mobile:android": "yarn workspace @reciclame/mobile android",
    "mobile:ios": "yarn workspace @reciclame/mobile ios",
    "mobile:web": "yarn workspace @reciclame/mobile web",
    "mobile:lint": "yarn workspace @reciclame/mobile lint",
    "mobile:test:coverage": "yarn workspace @reciclame/mobile test:coverage",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase db push",
    "db:diff": "supabase db diff",
    "db:schemas:refresh": "node scripts/generate-supabase-schemas.mjs",
    "test:coverage": "yarn mobile:test:coverage",
    "db:types": "supabase gen types typescript --local > packages/database-types/src/database.types.ts",
    "admin-web:dev": "yarn workspace @reciclame/admin-web dev",
    "admin-web:build": "yarn workspace @reciclame/admin-web build",
    "admin-web:lint": "yarn workspace @reciclame/admin-web lint",
    "admin-web:test": "yarn workspace @reciclame/admin-web test",
    "web:dev": "yarn admin-web:dev",
    "web:build": "yarn admin-web:build",
    "web:lint": "yarn admin-web:lint",
    "lint": "yarn mobile:lint && yarn admin-web:lint",
    "typecheck": "yarn workspace @reciclame/mobile tsc --noEmit && yarn workspace @reciclame/admin-web tsc --noEmit -p tsconfig.app.json",
    "db:test:contracts": "node scripts/run-supabase-contract-tests.mjs",
    "db:test:rls": "node scripts/run-supabase-rls-tests.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^8.0.0",
    "supabase": "^2.101.0"
  }
}
