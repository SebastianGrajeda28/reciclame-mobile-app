{
  "name": "reciclame",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "apps/admin-web",
    "packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "prepare": "husky install",
    "postinstall": "node scripts/patch-skia.mjs",
    "mobile:dev": "bun run --cwd apps/mobile dev",
    "mobile:start": "bun run --cwd apps/mobile start",
    "mobile:android": "bun run --cwd apps/mobile android",
    "mobile:ios": "bun run --cwd apps/mobile ios",
    "mobile:web": "bun run --cwd apps/mobile web",
    "mobile:lint": "bun run --cwd apps/mobile lint",
    "mobile:test:coverage": "bun run --cwd apps/mobile test:coverage",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase db push",
    "db:diff": "supabase db diff",
    "db:schemas:refresh": "node scripts/generate-supabase-schemas.mjs",
    "test:coverage": "bun run mobile:test:coverage",
    "db:types": "bunx supabase gen types typescript --local > packages/database-types/src/database.types.ts",
    "admin-web:dev": "bun run --cwd apps/admin-web dev",
    "admin-web:build": "bun run --cwd apps/admin-web build",
    "admin-web:lint": "bun run --cwd apps/admin-web lint",
    "admin-web:test": "bun run --cwd apps/admin-web test",
    "web:dev": "bun run admin-web:dev",
    "web:build": "bun run admin-web:build",
    "web:lint": "bun run admin-web:lint",
    "lint": "bun run mobile:lint && bun run admin-web:lint",
    "typecheck": "bun run --cwd apps/mobile tsc --noEmit && bun run --cwd apps/admin-web tsc --noEmit -p tsconfig.app.json",
    "db:test:contracts": "node scripts/run-supabase-contract-tests.mjs",
    "db:test:rls": "node scripts/run-supabase-rls-tests.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^8.0.0",
    "supabase": "^2.101.0"
  },
  "trustedDependencies": [
    "unrs-resolver",
    "@shopify/react-native-skia"
  ]
}
