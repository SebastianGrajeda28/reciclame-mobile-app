{
  "name": "@reciclame/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start --clear --tunnel",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"app/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\" \"*.{js,json,md}\" --write",
    "format:check": "prettier \"app/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\" \"*.{js,json,md}\" --check",
    "check": "npm run lint && npm run format:check",
    "test:watch": "bun test --env-file .env --preload ./tests/bun-setup.ts --watch",
    "test:coverage": "bun test --env-file .env --preload ./tests/bun-setup.ts --coverage tests/utils tests/map tests/supabase-connection.test.ts tests/supabase.test.ts",
    "test:components": "jest --config jest.components.config.js"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@reciclame/database-types": "workspace:*",
    "@reciclame/shared-domain": "workspace:*",
    "@shopify/react-native-skia": "^2.6.4",
    "@supabase/supabase-js": "^2.105.4",
    "@types/jpeg-js": "^0.3.7",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-camera": "~17.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-file-system": "~19.0.23",
    "expo-device": "^56.0.4",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.7",
    "expo-notifications": "^56.0.18",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~15.2.14",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "isomorphic-ws": "^5.0.0",
    "jest-expo": "~54.0.17",
    "jpeg-js": "^0.4.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fast-tflite": "^3.0.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "react-test-renderer": "19.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@types/ws": "^8.18.1",
    "babel-preset-expo": "~54.0.0",
    "bun-types": "^1.3.14",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20 <25",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {}
  },
  "private": true,
  "trustedDependencies": [
    "unrs-resolver",
    "@shopify/react-native-skia"
  ]
}
