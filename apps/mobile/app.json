{
  "expo": {
    "name": "Recíclame",
    "slug": "reciclame-mobile-app",
    "version": "1.12.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "reciclamemobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wolgank.reciclame",
      "config": {
        "googleMapsApiKey": "AIzaSyCsWNjZBe4Tmvkx9AN3ZTQ74HhaP-J9pZw"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wolgank.reciclame",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "reciclamemobileapp",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#002F4E",
        "foregroundImage": "./assets/images/ic_launcher_foreground.png",
        "backgroundImage": "./assets/images/ic_launcher_background.png",
        "monochromeImage": "./assets/images/ic_launcher_monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCsWNjZBe4Tmvkx9AN3ZTQ74HhaP-J9pZw"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Recíclame necesita acceso a la cámara para escanear residuos reciclables."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Recíclame necesita tu ubicación para mostrarte contenedores cercanos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Recíclame necesita acceso a tu galería para seleccionar fotos de residuos reciclables."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/reciclame-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#26B0CF33",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "react-native-fast-tflite",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5ad88413-f15a-4ce6-8929-65fb3d19a3b7"
      }
    }
  }
}
